# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Web Push (PWA) — gere um par com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# Edge Functions (Supabase Dashboard → Project Settings → Edge Functions)
# Defina no Supabase:
# - VAPID_PRIVATE_KEY
# - VAPID_PUBLIC_KEY (mesmo do NEXT_PUBLIC acima)
# - GITHUB_WEBHOOK_SECRET_<REPO_UUID> (opcional, por repositório)
