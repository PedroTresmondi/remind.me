# API Docker / PostgreSQL local (docker compose)
PORT=3000
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=remindme
DATABASE_URL=postgresql://postgres:postgres@db:5432/remindme

# Azure Container Instances (mesmo container group: DB_HOST=localhost)
# DB_HOST=localhost
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/remindme

